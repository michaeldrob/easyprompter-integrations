{
  "name": "companion-module-easyprompter",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json -w",
    "package": "pnpm build && companion-module-build",
    "check": "companion-module-check",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "dependencies": {
    "@companion-module/base": "^2.0.0",
    "@easyprompter/remote-client": "workspace:*"
  },
  "devDependencies": {
    "@companion-module/tools": "^2.0.0",
    "@types/node": "^22.0.0",
    "lucide-static": "^1.21.0",
    "rimraf": "^6.0.0",
    "sharp": "^0.35.2",
    "typescript": "^5.7.0"
  }
}

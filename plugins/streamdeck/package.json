{
  "name": "streamdeck-plugin",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "src/plugin.ts",
  "scripts": {
    "build": "rollup -c --environment BUILD:production",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.easyprompter.streamdeck\"",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.0",
    "@easyprompter/remote-client": "workspace:*"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@elgato/schemas": "^0.4.15",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "rollup": "^4.28.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0"
  }
}
